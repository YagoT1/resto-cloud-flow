  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://tozxaevzkqlrzxpyzmul.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "restocloud-mcp",
      "version": "0.1.0",
      "title": "RestoCloud MCP"
    },
    "tools": [
      {
        "name": "whoami",
        "title": "Who am I",
        "description": "Return the signed-in user's profile, roles, and restaurant. Useful to verify connectivity and identity.",
        "annotations": {
          "readOnlyHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
